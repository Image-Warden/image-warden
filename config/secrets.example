# image-warden secrets
# Copy to: ~/.config/image-warden/secrets
# chmod 600 ~/.config/image-warden/secrets

#--- Discord ------------------------------------------------------------------
# Edit channel settings -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=""

#--- Slack --------------------------------------------------------------------
# https://api.slack.com/messaging/webhooks
# Create App, use "Incoming Webhook" or "From Scratch", Add Incoming Webhook
SLACK_WEBHOOK_URL=""

# --- Microsoft Teams ---------------------------------------------------------
# Requires: Teams "Incoming Webhook" connector on the target channel.
# Channel settings -> Connectors, add Incoming Webhook -> Configure -> Copy URL
# Note: Microsoft is migrating connectors to Power Automate Workflows.
# If your tenant has disabled legacy connectors, use the Workflow webhook
# and set TEAMS_WEBHOOK_URL to the Power Automate URL, the payload format
# (MessageCard) is accepted by both.
TEAMS_WEBHOOK_URL=""

# --- Telegram ----------------------------------------------------------------
# 1. Message @BotFather, use "/newbot"command, copy the token
# 2. Add the bot to your group/channel, then:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates" to find chat id
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- ntfy --------------------------------------------------------------------
# Self-hosted or public: https://ntfy.sh/
# NTFY_URL: full topic URL, e.g. https://ntfy.sh/my-secret-topic
# NTFY_TOKEN: only needed for access-controlled topics (leave empty otherwise)
NTFY_URL=""
NTFY_TOKEN=""
